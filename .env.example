# Copy this file to .env on each host. Keep .env out of Git.

# Network and service ports
AI_MAX_IP=192.168.64.246
SERVER_PC_IP=192.168.250.30
TB3_IP=192.168.250.10
SERVER_DASHBOARD_PORT=8775
TB3_UI_PORT=8765

# VLM
VLM_MODEL=qwen3vl8b
VLM_PORT=18082
VLM_CONTEXT_SIZE=4096
VLM_GPU_LAYERS=999
VLM_WAIT_TIMEOUT_S=180
VLM_DASHBOARD_PORT=18181

# ROS and behavior
ROS_DOMAIN_ID=30
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
TB3_BEHAVIOR_DRY_RUN=true
TB3_BEHAVIOR_MAX_DURATION=1.5

# Existing host workspaces
SERVER_COMPOSE_DIR=/home/user/ROS_Cui/turtlebot3/docker/jazzy
TB3_COMPOSE_DIR=/home/turtlebot3/turtlebot3/docker/jazzy
ROS_CONTAINER=turtlebot3
SERVER_REPO_DIR=/home/user/ROS_Cui/turtlebot3/docker/jazzy/workspace/ros2_ws/src/tb3_multimodal_interaction
TB3_REPO_DIR=/home/turtlebot3/turtlebot3/docker/jazzy/workspace/ros2_ws/src/tb3_multimodal_interaction

# External assets excluded from Git
AI_MAX_ROOT=/home/user/ROS_Cui
AI_MAX_REPO_DIR=/home/user/ROS_Cui/tb3-multimodal-interaction
LLAMA_CPP_DIR=/home/user/ROS_Cui/llama.cpp
LLAMA_SERVER=/home/user/ROS_Cui/llama.cpp/build/bin/llama-server
VLM_MODEL_PATH=/home/user/.cache/huggingface/hub/models--Qwen--Qwen3-VL-8B-Instruct-GGUF/snapshots/f982a07559d4a2f6c8744d840bf6fccab30eea96/Qwen3VL-8B-Instruct-Q4_K_M.gguf
VLM_MMPROJ_PATH=/home/user/.cache/huggingface/hub/models--Qwen--Qwen3-VL-8B-Instruct-GGUF/snapshots/f982a07559d4a2f6c8744d840bf6fccab30eea96/mmproj-Qwen3VL-8B-Instruct-Q8_0.gguf
SENSEVOICE_MODEL_DIR=/home/user/ROS_Cui/turtlebot3/docker/jazzy/model_cache/SenseVoiceSmall

# TurtleBot3 hardware and display
TB3_CAMERA_DEVICE=/dev/video0
TB3_OPENCR_DEVICE=/dev/ttyACM0
TB3_LIDAR_DEVICE=/dev/tb3_lidar
TB3_MIC_ALSA_DEVICE=plughw:CARD=Device,DEV=0
TB3_SPEAKER_ALSA_DEVICE=plughw:CARD=UACDemoV10,DEV=0
TB3_DISPLAY=:0

# Host readiness policy
NTP_REQUIRED=true

# Persistent runtime logs and lifecycle state
# Server/TB3 paths are on the host side of the existing ./workspace:/workspace mount.
AI_MAX_RUNTIME_LOG_DIR=/home/user/ROS_Cui/runtime_logs/tb3_multimodal_interaction
SERVER_RUNTIME_LOG_DIR=/home/user/ROS_Cui/turtlebot3/docker/jazzy/workspace/runtime_logs/tb3_multimodal_interaction
TB3_RUNTIME_LOG_DIR=/home/turtlebot3/turtlebot3/docker/jazzy/workspace/runtime_logs/tb3_multimodal_interaction
CONTAINER_RUNTIME_LOG_DIR=/workspace/runtime_logs/tb3_multimodal_interaction
RUNTIME_LOG_RETENTION_DAYS=14
RUNTIME_LOG_RETAIN_FILES=20
ROLE_STARTUP_GRACE_S=180
